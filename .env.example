# ==========================================================================
# Feira do Rolo — API · .env.example
#
# AQUI ficam APENAS o bootstrap do processo e os SEGREDOS-RAIZ. Todo o resto
# (credenciais de gateway/integrações, URLs públicas, CORS, remetente de e-mail,
# comissões, frete, destaques, validade de token, etc.) é gerenciado pelo
# ADMIN no banco, via painel /admin. Ver src/documentacao/INTEGRACOES.md.
# ==========================================================================

# --- Bootstrap do processo ---
NODE_ENV=development
PORT=3333
APP_API_PREFIX=/api/v1
LOG_LEVEL=info

# --- Banco de Dados (PostgreSQL / Neon) ---
# Não pode ir para o banco (é a própria conexão).
DATABASE_URL=postgres://user:password@host:5432/feiradorolo
DB_SSL=true              # false em Postgres local sem SSL
DB_LOGGING=false

# --- Segredos-raiz (NÃO podem viver no banco que eles protegem) ---
# JWT_SECRET assina os tokens; APP_ENCRYPTION_KEY decifra os segredos guardados
# no banco (gateway/integrações). Guardá-los no banco anularia a proteção.
JWT_SECRET=troque-por-um-segredo-forte
APP_ENCRYPTION_KEY=        # 32 bytes em hex (64 chars). Vazio = derivado do JWT_SECRET (apenas dev).

# --- Bootstrap do super admin (usado só pelo seeder) ---
ADMIN_EMAIL=admin@feiradorolo.com
ADMIN_PASSWORD=ChangeMe123!   # TROQUE em produção
ADMIN_NAME=Super Admin

# (Opcional) TTL dos caches em memória — ajuste fino de performance.
# SETTINGS_CACHE_TTL_MS=60000
# PERMISSION_CACHE_TTL_MS=30000
# MODERATION_CACHE_TTL_MS=60000

# --------------------------------------------------------------------------
# Configurado no PAINEL ADMIN (não aqui):
#   • app.public_url / app.web_url / app.cors_origins / app.name   (platform_settings)
#   • mail.from_email / mail.from_name / auth.jwt_expires_in        (platform_settings)
#   • Mercado Pago (client_id/secret/access_token, OAuth)           (payment_gateway_settings)
#   • Melhor Envio / Firebase / Brevo / Zoho / FCM / OneSignal      (integration_settings, cifrado)
#   • Comissões, escrow, frete/markup, destaques, cupons, etc.      (tabelas de regras)
# --------------------------------------------------------------------------
